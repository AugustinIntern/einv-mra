# MRA API Credentials
MRA_USERNAME=your_username
MRA_PASSWORD=your_password
MRA_EBS_MRA_ID=your_ebs_mra_id
MRA_AREA_CODE=100

# MRA API Endpoints (use vfisc for testing, fisc for production)
MRA_AUTH_URL=https://vfisc.mra.mu/einvoice-token-service/token-api/generate-token
MRA_INVOICE_URL=https://vfisc.mra.mu/realtime/invoice/transmit

# Path to the MRA public key certificate (.crt file)
# On Vercel: paste the certificate content as an env var instead
MRA_PUBLIC_KEY_PATH=./PublicKey.crt
# OR paste the cert content directly (preferred for Vercel):
# MRA_PUBLIC_KEY_CONTENT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# Server
PORT=3000
NODE_ENV=development
